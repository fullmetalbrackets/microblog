---
import BaseHead from '../components/BaseHead.astro';
import Header from '@components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

const { title } = Astro.props.frontmatter || Astro.props;
const { description } = Astro.props.frontmatter || Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <BaseHead title={title} description={description} />
    <ClientRouter />
    <style>
        #root,
        #__next {
            isolation: isolate;
        }

        :root,
        html {
            --bg: oklch(15.177% 0.02955 265.398);
            --text: oklch(91.87% 0.003 264.54);
            --accent: hotpink;
            --pink: oklch(82.23% 0.112 355.33);
            --green: oklch(70.03% 0.194 144.71);
            --yellow: oklch(89% 0.146 91.5);
            --gray: oklch(59.987% 0.00007 271.152);
            --gray-light: oklch(78.261% 0.00009 271.152);
            --gray-dark: oklch(28.167% 0.03131 266.133);
            --gray-gradient: rgba(var(--gray-light), 50%), #fff;
            --border: rgba(255, 166, 200, 0.5);
            --box-shadow:
                0 2px 6px rgba(var(--gray), 25%), 0 8px 24px rgba(var(--gray), 33%),
                0 16px 32px rgba(var(--gray), 33%);
            scroll-behavior: smooth;
            max-width: 100vw;
            height: 100%;
            -moz-osx-font-smoothing: antialiased;
            -webkit-font-smoothing: antialiased;
            -webkit-tap-highlight-color: rgba(0, 0, 0, 0);
            font-variant-ligatures: no-common-ligatures;
            scroll-behavior: smooth;
        }

        ::selection {
            color: #000;
            background-color: var(--gray);
        }

        ::-moz-selection {
            color: #000;
        }

        body {
            display: flex;
            flex-direction: column;
            font-family: var(--bricolage);
            font-weight: 400;
            background: var(--bg);
            color: var(--text);
            margin: 0 auto;
            padding: 0;
            word-wrap: break-word;
            overflow-wrap: break-word;
            font-size: 24px;
            visibility: visible;
            opacity: 1;
            transition: visibility 0.5s linear, opacity 0.5s linear;
            min-height: 100vh;
            max-width: 100vw;
            overflow-y: scroll;
            overflow-x: hidden;
        }

        main {
            flex: 1;
            width: min(720px, 100%);
            margin: 0 auto;
            padding: 0 1em;
            animation: 0.25s fade-in;
            
        }
        
        @keyframes fade-in {
            0% {
                opacity: 0;
            }

            100% {
                opacity: 1;
            }
        }

        @keyframes wiggle {
            0%,
            100% {
                transform: rotate(0deg);
            }
            25% {
                transform: rotate(-10deg);
            }
            75% {
                transform: rotate(10deg);
            }
        }

        .skip-link {
            position: absolute;
            top: -100%;
            left: 0;
            padding: 0.5em 1em;
            background: var(--yellow);
            color: #000;
            font-size: 0.85em;
            z-index: 999;
        }

        .skip-link:focus {
            top: 0;
        }
    </style>
</head>
<body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header />
    <main id="main-content" tabindex="-1">
        <slot>
            <p>
                If you're seeing this, something went wrong! Please try <em>reloading the page</em>.
            </p>
        </slot>
    </main>
    <Footer/>
</body>
</html>